{
  "name": "book-management-system",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "server": "json-server --watch db.json --port 3001",
    "start:api": "json-server --watch db.json --host 0.0.0.0 --port 3001",
    "start": "concurrently \"npm run server\" \"npm run dev\""
  },
  "dependencies": {
    "json-server": "^1.0.0-beta.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.1.0",
    "typescript": "~5.6.2",
    "vite": "^5.4.10"
  }
}
